{
  "name": "@meal-planner/electron",
  "version": "0.0.0",
  "private": true,
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm run build && electron .",
    "dist": "pnpm run build && electron-builder",
    "lint": "eslint --max-warnings=0 .",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "build": {
    "appId": "com.mealplanner.desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../app/dist/app/browser",
        "to": "app/browser"
      }
    ],
    "mac": {
      "category": "public.app-category.food-and-drink"
    }
  },
  "dependencies": {
    "@meal-planner/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "electron": "34.5.8",
    "electron-builder": "^26.0.12",
    "typescript": "6.0.2"
  }
}
